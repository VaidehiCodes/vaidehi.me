---
import I18NDebug from "@ariaskit/astro-i18n/I18NDebug.astro";

interface Props {
  nav: { path: string; text: string }[];
}

const { nav } = Astro.props as Props;
---

<header class="py-15 flex items-center justify-between gap-4 flex-col md:flex-row fixed top-0 left-1/2 -translate-x-1/2 bg-background z-40">
  <div class="flex items-center gap-5 order-2 md:order-1">
    {
      nav.map((item) => (
        <I18NDebug key={item.text}>
          <a
            class="opacity-50 transition-all duration-200 hover:opacity-100 text-[1rem] md:text-[0.85rem]"
            href={item.path}
          >
            {item.text}
          </a>
        </I18NDebug>
      ))
    }
  </div>

  <button
    type="button"
    data-theme-toggle
    aria-label="toggle theme"
    class="order-1 md:order-2 h-4 w-4 rounded-full bg-foreground border border-border transition-opacity duration-200 hover:opacity-80"
  ></button>

  <div class="absolute -bottom-10 left-0 w-full h-18 pointer-events-none bg-linear-to-b from-background via-background/80 to-background/20 z-10"></div>
</header>

<script is:inline>
  const root = document.documentElement;
  const storageKey = "theme";

  const applyTheme = (theme) => {
    root.classList.toggle("dark", theme === "dark");
    localStorage.setItem(storageKey, theme);
  };

  const initialTheme =
    localStorage.getItem(storageKey) ||
    (root.classList.contains("dark") ? "dark" : "light");

  applyTheme(initialTheme);

  const bindThemeToggle = () => {
    document.querySelectorAll("[data-theme-toggle]").forEach((button) => {
      if (button.getAttribute("data-theme-bound") === "true") return;
      button.setAttribute("data-theme-bound", "true");

      button.addEventListener("click", () => {
        applyTheme(root.classList.contains("dark") ? "light" : "dark");
      });
    });
  };

  bindThemeToggle();
  document.addEventListener("astro:after-swap", bindThemeToggle);
</script>