---
import I18NDebug from "@ariaskit/astro-i18n/I18NDebug.astro";

type Out = { key: string; value: string };

interface BookEntry {
    period: Out;
    book: Out;
    author: Out;
    description: Out;
}

interface Props {
    title: Out;
    books: BookEntry[];
}

const { title, books } = Astro.props as Props;
---

<section id={title.value.toLowerCase()} class="scroll-mt-50">
    <h2 class="opacity-50 uppercase mb-6 mt-15">
        <I18NDebug key={title.key}>
            {title.value}
        </I18NDebug>
    </h2>
    {
        books.map((entry) => (
            <ul>
                <li class="mb-4 grid grid-cols-1 md:grid-cols-10">
                    <span class="opacity-50 text-[0.87rem] col-span-2">
                        <I18NDebug key={entry.period.key}>
                            {entry.period.value}
                        </I18NDebug>
                    </span>
                    <div class="col-span-8">
                        <div>
                            <I18NDebug key={entry.book.key}>
                                <span>{entry.book.value}</span>
                            </I18NDebug>
                            <span class="opacity-50">|</span>
                            <I18NDebug key={entry.author.key}>
                                <span>{entry.author.value}</span>
                            </I18NDebug>
                        </div>
                        <I18NDebug key={entry.description.key}>
                            <p class="text-[0.87rem] opacity-50">
                                {entry.description.value}
                            </p>
                        </I18NDebug>
                    </div>
                </li>
            </ul>
        ))
    }
</section>
